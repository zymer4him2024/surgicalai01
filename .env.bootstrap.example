# .env.bootstrap.example — Universal RPi Bootstrap
# Copy to .env on a fresh RPi before running docker-compose.bootstrap.yml
#
# Usage:
#   cp .env.bootstrap.example .env
#   # Edit DEVICE_ID below
#   docker compose -f docker-compose.bootstrap.yml up -d --build
#
# After setup, assign this device to a project from the admin dashboard.
# The launcher service will automatically switch to the correct application stack.

# Device Identity — set a unique ID for this RPi
DEVICE_ID=US-RPi-001

# Project assignment (set by admin dashboard on device assignment)
# PROJECT_ID=

# 3rd party AI authentication (set if using external AI model)
# EXTERNAL_AI_TOKEN=

# Firebase — same for all devices
FIREBASE_PROJECT_ID=surgicalai01
FIREBASE_STORAGE_BUCKET=surgicalai01.firebasestorage.app
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
