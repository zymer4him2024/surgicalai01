# .env.gas.example — Gas Cylinder Inventory Counting
# Copy to .env on the gas RPi before running docker compose.
#
# Usage:
#   cp .env.gas.example .env
#   docker compose -f docker-compose.gas.yml up -d --build

# Device Identity
APP_ID=inventory_count
DEVICE_ID=US-Gas-001

# Gas-specific config
LOW_STOCK_THRESHOLD=5
SYNC_INTERVAL_SEC=60
LOCATION_NAME=Warehouse A
OPERATOR_ID=
CUSTOMER_DB_URL=

# Project assignment (set by admin dashboard on device assignment)
# PROJECT_ID=

# 3rd party AI authentication (set if using external AI model)
# EXTERNAL_AI_TOKEN=

# Security (optional — if set, POST /snapshot requires X-API-Key header)
GATEWAY_API_KEY=

# Inference model (replace with trained gas cylinder model when ready)
GAS_HEF_MODEL=surgeonet_416.hef

# Firebase
FIREBASE_PROJECT_ID=surgicalai01
FIREBASE_STORAGE_BUCKET=surgicalai01.firebasestorage.app
FIRESTORE_COLLECTION=inventory_count_events
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
