rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Raw model uploads — authenticated users can write; converter service reads via service account
    match /uploads/raw/{modelId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 500 * 1024 * 1024  // 500 MB limit
                   && (filename.matches('.*\\.pt') ||
                       filename.matches('.*\\.onnx') ||
                       filename.matches('.*\\.har'));
    }

    // Compiled HEF outputs — written by service account; authenticated users can read
    match /models/hef/{modelId}/{filename} {
      allow read: if request.auth != null;
      allow write: if false;  // Only service account (backend) writes here
    }

    // Error snapshots from edge devices (existing)
    match /snapshots/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
