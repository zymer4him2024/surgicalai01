rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function validDeviceFields() {
      let d = request.resource.data;
      return d.device_id is string
          && d.device_id.size() > 0
          && d.device_id.size() <= 64
          && d.app_id in ['surgical', 'od', 'inventory', 'inventory_count', 'unassigned'];
    }

    // Users — authenticated users can read/write their own profile; admins can update any user
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Device registry — authenticated users can read;
    // Writes: device self-registration requires valid identity fields;
    // Admin metadata updates (project_id, location, customer_id) allowed without identity fields.
    match /devices/{deviceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && validDeviceFields();
      allow update: if isAuthenticated() && (
        validDeviceFields()
        || !request.resource.data.keys().hasAny(['device_id', 'app_id'])
      );
      allow delete: if isAuthenticated();
    }

    // App Types — authenticated users can read and write
    match /app_types/{appTypeId} {
      allow read, write: if isAuthenticated();
    }

    // Applications — authenticated users can read and write
    match /applications/{applicationId} {
      allow read, write: if isAuthenticated();
    }

    // Models — authenticated users can read and write
    match /models/{modelId} {
      allow read, write: if isAuthenticated();
    }

    // Projects — authenticated users can read and write
    match /projects/{projectId} {
      allow read, write: if isAuthenticated();
    }

    // Customers — authenticated users can read and write
    match /customers/{customerId} {
      allow read, write: if isAuthenticated();
    }

    // Sync events — backend (Admin SDK) writes only; authenticated users can read
    match /sync_events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // System status — backend writes only; authenticated users can read
    match /system_status/{deviceId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Device control — authenticated users can read and write (control panel)
    match /device_control/{deviceId} {
      allow read, write: if isAuthenticated();
    }

    // Job config (preset cycles) — authenticated users can read and write
    match /job_config/{deviceId} {
      allow read, write: if isAuthenticated();
    }

    // Inspection log — backend writes only; authenticated users can read
    match /inspection_log/{deviceId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Operations — full history of inspection rounds; backend writes only
    match /operations/{operationId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Gas inventory count events — backend (Admin SDK) writes only
    match /inventory_count_events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Gas config — per-device configuration (threshold, location, operator)
    match /gas_config/{deviceId} {
      allow read, write: if isAuthenticated();
    }
  }
}
